{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Quidkey Docs",
  "colors": {
    "primary": "#3A81FF",
    "light": "#CEDFFF",
    "dark": "#3A81FF"
  },
  "favicon": "https://storage.googleapis.com/quidkey-resources-public/quidkey-logo-fav.png",
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://quidkey.com/blog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Shopify",
            "pages": [
              "guides/shopify/onboarding"
            ]
          },
          {
            "group": "Embedded Flow (with Stripe)",
            "pages": [
              "guides/embedded-flow/overview",
              "guides/embedded-flow/create",
              "guides/embedded-flow/embed",
              "guides/embedded-flow/after-payment"
            ]
          },
          {
            "group": "Payment Links",
            "pages": [
              "guides/payment-links/overview",
              "guides/payment-links/console",
              "guides/payment-links/create",
              "guides/payment-links/checkout-experience",
              "guides/payment-links/after-payment"
            ]
          },
          {
            "group": "Payouts",
            "pages": [
              "guides/payouts/overview",
              "guides/payouts/export"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Authentication",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "api-reference/endpoint/issue-token",
              "POST /api/v1/oauth2/refresh"
            ]
          },
          {
            "group": "Embedded Payment Flow",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /api/v1/embedded/payment-requests",
              "PATCH /api/v1/embedded/payment-requests",
              "POST /api/v1/embedded/payment-initiation"
            ]
          },
          {
            "group": "Payment Links",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /api/v1/payment-links",
              "GET /api/v1/payment-links",
              "GET /api/v1/payment-links/{id}"
            ]
          },
          {
            "group": "Webhooks",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /api/v1/webhooks",
              "POST /api/v1/webhooks/secret",
              "POST /api/v1/webhooks/secret/revoke"
            ]
          }
        ]
      },
      {
        "tab": "Payment API",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "guides/payment-api/overview",
              "guides/payment-api/quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "guides/payment-api/concepts/authentication",
              "guides/payment-api/concepts/idempotency",
              "guides/payment-api/concepts/errors",
              "guides/payment-api/concepts/webhooks",
              "guides/payment-api/concepts/testing",
              "guides/payment-api/concepts/amounts-and-currencies"
            ]
          },
          {
            "group": "Accept a payment",
            "pages": [
              "guides/payment-api/accept-a-payment/redirect",
              "guides/payment-api/accept-a-payment/embedded",
              "guides/payment-api/accept-a-payment/hosted-checkout"
            ]
          },
          {
            "group": "API reference",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /api/v1/oauth2/token",
              "POST /api/v1/oauth2/refresh",
              "POST /api/v1/payment-requests:redirect",
              "GET /api/v1/banks/top",
              "POST /api/v1/embedded/payment-requests",
              "PATCH /api/v1/embedded/payment-requests",
              "POST /api/v1/payment-links",
              "GET /api/v1/payment-links/{id}",
              "GET /api/v1/payment-requests/{paymentRequestId}/status",
              "POST /api/v1/webhooks",
              "POST /api/v1/webhooks/secret",
              "POST /api/v1/webhooks/secret/revoke"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:rabea@quidkey.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://console.quidkey.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/quidkeyHQ",
      "github": "https://github.com/quidkey",
      "linkedin": "https://linkedin.com/company/quidkey"
    }
  }
}
